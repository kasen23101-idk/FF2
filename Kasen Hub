    local SAVE_FILE = "kasen_hub_keys.json"
    local http  = game:GetService("HttpService")
    local lp    = game:GetService("Players").LocalPlayer
    local pg    = lp:FindFirstChildOfClass("PlayerGui") or lp:WaitForChild("PlayerGui", 10)

    local function loadActivations()
        if typeof(readfile) ~= "function" then return {} end
        local ok, raw = pcall(readfile, SAVE_FILE)
        if not ok or type(raw) ~= "string" or raw == "" then return {} end
        local ok2, data = pcall(function() return http:JSONDecode(raw) end)
        if ok2 and type(data) == "table" then return data end
        return {}
    end

    local function saveActivations(t)
        if typeof(writefile) ~= "function" then return end
        local ok, encoded = pcall(function() return http:JSONEncode(t) end)
        if ok then pcall(writefile, SAVE_FILE, encoded) end
    end

    local function now() return math.floor(tick()) end
    local function daysToSec(d) return d * 86400 end

    local function fmtTime(s)
        if s >= 86400*365*50 then return "Lifetime" end
        local d = math.floor(s/86400)
        local h = math.floor((s%86400)/3600)
        if d > 0 then return d.."d "..h.."h left" end
        return h.."h "..math.floor((s%3600)/60).."m left"
    end

