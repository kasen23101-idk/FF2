addSlider = function(pg, lbl, mn, mx, def, isFloat, callback)
    local val = def; local dragging = false
    local THUMB  = isMobile and 30 or 22
    local TRACK_H = isMobile and 34 or 26
    local WRAP_H  = isMobile and 68 or 56

    local wrap = Instance.new("Frame", pg)
    wrap.BackgroundTransparency=1; wrap.Size=UDim2.new(1,0,0,WRAP_H)

    local lbl2 = Instance.new("TextLabel", wrap)
    lbl2.BackgroundTransparency=1; lbl2.Position=UDim2.new(0,0,0,2); lbl2.Size=UDim2.new(1,0,0,22)
    lbl2.Font=Enum.Font.GothamBold; lbl2.TextColor3=C.text
    lbl2.TextSize=isMobile and 14 or 13; lbl2.TextXAlignment=Enum.TextXAlignment.Left

    local function fmtV(v) return lbl..": "..string.format("%.2f", v) end
    lbl2.Text = fmtV(val)

    local track = Instance.new("Frame", wrap)
    track.BackgroundColor3=C.card; track.BorderSizePixel=0
    track.Position=UDim2.new(0,0,0,28); track.Size=UDim2.new(1,0,0,TRACK_H)
    Instance.new("UICorner", track).CornerRadius=UDim.new(0,6)

    local rail = Instance.new("Frame", track)
    rail.BackgroundColor3=Color3.fromRGB(28,38,58); rail.BorderSizePixel=0
    rail.Position=UDim2.new(0,16,0.5,-5); rail.Size=UDim2.new(1,-32,0,10)
    Instance.new("UICorner", rail).CornerRadius=UDim.new(1,0)

    local pct = (def-mn)/math.max(mx-mn,0.001)
    local fill = Instance.new("Frame", rail)
    fill.BackgroundColor3=C.accent; fill.BorderSizePixel=0
    fill.Size=UDim2.new(pct,0,1,0)
    Instance.new("UICorner", fill).CornerRadius=UDim.new(1,0)

    local hitBtn = Instance.new("TextButton", track)
    hitBtn.BackgroundTransparency=1; hitBtn.BorderSizePixel=0
    hitBtn.Position=UDim2.new(0,0,-0.5,0); hitBtn.Size=UDim2.new(1,0,2,0)
    hitBtn.Text=""; hitBtn.AutoButtonColor=false; hitBtn.ZIndex=4

    local half = THUMB/2
    local thumb = Instance.new("Frame", rail)
    thumb.BackgroundColor3=Color3.fromRGB(255,255,255); thumb.BorderSizePixel=0
    thumb.Position=UDim2.new(pct,-half,0.5,-half); thumb.Size=UDim2.new(0,THUMB,0,THUMB)
    thumb.ZIndex=5
    Instance.new("UICorner", thumb).CornerRadius=UDim.new(1,0)
    local tStroke = Instance.new("UIStroke", thumb)
    tStroke.Color=C.accentDim; tStroke.Thickness=1.5

    local function updateFromInput(inputX)
        local sz = rail.AbsoluteSize.X; if sz<=1 then return end
        local rel = math.clamp((inputX - rail.AbsolutePosition.X)/sz, 0, 1)
        local raw = mn + rel*(mx-mn)
        local r = isFloat and math.floor(raw*100+0.5)/100 or math.floor(raw*10+0.5)/10
        val = r
        TS:Create(fill, TweenInfo.new(0.04, Enum.EasingStyle.Linear), {Size=UDim2.new(rel,0,1,0)}):Play()
        thumb.Position = UDim2.new(rel,-half,0.5,-half)
        lbl2.Text = fmtV(r)
        if callback then callback(r) end
    end

    hitBtn.MouseButton1Down:Connect(function()
        dragging=true; updateFromInput(UIS:GetMouseLocation().X)
        TS:Create(thumb,TweenInfo.new(0.08),{Size=UDim2.new(0,THUMB+6,0,THUMB+6),BackgroundColor3=C.accentHi}):Play()
    end)
    hitBtn.TouchLongPress:Connect(function(positions)
        dragging=true
        if #positions>0 then updateFromInput(positions[1].X) end
        TS:Create(thumb,TweenInfo.new(0.08),{Size=UDim2.new(0,THUMB+6,0,THUMB+6),BackgroundColor3=C.accentHi}):Play()
    end)
    thumb.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true; updateFromInput(i.Position.X) end end)
    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement then updateFromInput(UIS:GetMouseLocation().X)
        elseif i.UserInputType==Enum.UserInputType.Touch then updateFromInput(i.Position.X) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=false
            TS:Create(thumb,TweenInfo.new(0.1),{Size=UDim2.new(0,THUMB,0,THUMB),BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
        end
    end)
end

