        end
    end
        local best, bestScore = nil, math.huge
    local function tryAdd(m)
        local h = m:FindFirstChild("HumanoidRootPart"); if not h then return end
        local hum = m:FindFirstChild("Humanoid"); if hum and hum.Health <= 0 then return end
        local sp, onScreen = Camera:WorldToViewportPoint(h.Position)
        if not onScreen then return end
        local screenD = (Vector2.new(sp.X,sp.Y) - Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
        local worldD  = Hrp and (Hrp.Position - h.Position).Magnitude or 999
        local score   = (screenD/600)*0.6 + (worldD/200)*0.4
        if score < bestScore then bestScore = score; best = m end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Team == Player.Team and p.Character then
            tryAdd(p.Character)
        end
    end
    local npcwr = WS:FindFirstChild("npcwr")
    if npcwr then
        for _, d in pairs(npcwr:GetDescendants()) do
            if d:IsA("Model") and (d.Name == "bot 1" or d.Name == "bot 3") then tryAdd(d) end
        end
    end
    if best and best ~= qb_data.target then
        qb_data.target = best
        qb_HL.Adornee  = best
        qb_HL.Enabled  = qbEnabled
        qb_data.smoothVel = Vector3.new()
    end
