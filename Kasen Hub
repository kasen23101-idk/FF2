-- FTI alternates between begin/end on separate frames so the game registers each touch
local _ftiState = 0

RunService.Heartbeat:Connect(function(dt)
    if not Hrp or not magson then return end
    local ball = getfutbal(); if not ball then return end
    local cnp = tick()
    if magsdelayon and (cnp - lmgg) < magsdelay then return end
    local cp = catchPart(ball); if not cp then return end

    local dist = (ball.Position - cp.Position).Magnitude

    if magmode == "FTI" then
        if typeof(firetouchinterest) == "function" then
            -- alternate begin/end each frame so the game registers both states
            _ftiState = 1 - _ftiState
            pcall(firetouchinterest, ball, cp, _ftiState)
        else
            -- FTI not available, fall through to CFrame
            local t = math.clamp(dist / math.max(magsrange, 1), 0, 1)
            local ease = 1 - t * t * t
            local alpha = math.clamp(dt * (6 + ease * 18), 0, 0.92)
            pcall(function() ball.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
            if dist > 1.5 then
                local np = ball.Position:Lerp(cp.Position, alpha)
                local _,_,_,r00,r01,r02,r10,r11,r12,r20,r21,r22 = ball.CFrame:GetComponents()
                ball.CFrame = CFrame.new(np.X,np.Y,np.Z, r00,r01,r02,r10,r11,r12,r20,r21,r22)
            else
                ball.CFrame = ball.CFrame:Lerp(cp.CFrame, alpha)
            end
        end

    elseif magmode == "Smooth" then
        -- smooth position lerp, kills velocity so physics doesn't fight it
        local t = math.clamp(dist / math.max(magsrange, 1), 0, 1)
        local ease = 1 - t * t * t
        local alpha = math.clamp(dt * (10 + ease * 30), 0, 0.95)
        pcall(function() ball.AssemblyLinearVelocity = ball.AssemblyLinearVelocity * (1 - alpha) end)
        if dist > 1.2 then
            local np = ball.Position:Lerp(cp.Position, alpha)
            local _,_,_,r00,r01,r02,r10,r11,r12,r20,r21,r22 = ball.CFrame:GetComponents()
            ball.CFrame = CFrame.new(np.X,np.Y,np.Z, r00,r01,r02,r10,r11,r12,r20,r21,r22)
        else
            ball.CFrame = ball.CFrame:Lerp(cp.CFrame, alpha)
        end

    elseif magmode == "CFrame" then
        -- full CFrame snap, kills velocity completely for a tight snap feel
        local t = math.clamp(dist / math.max(magsrange, 1), 0, 1)
