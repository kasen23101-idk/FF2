local function qb_buildReceiverList()
    local list = {}
    local function tryAdd(m)
        local h = m:FindFirstChild("HumanoidRootPart"); if not h then return end
        local hum = m:FindFirstChild("Humanoid"); if hum and hum.Health <= 0 then return end
        local sp, onScreen = Camera:WorldToViewportPoint(h.Position)
        local screenD = onScreen
            and (Vector2.new(sp.X,sp.Y) - Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
            or 9999
        local worldD = Hrp and (Hrp.Position - h.Position).Magnitude or 999
        local score  = (screenD/600)*0.6 + (worldD/200)*0.4
        local tp = Players:GetPlayerFromCharacter(m)
        local nm = (tp and (tp.DisplayName ~= "" and tp.DisplayName or tp.Name)) or m.Name or "?"
        table.insert(list, {char=m, name=nm, score=score})
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Team == Player.Team and p.Character then tryAdd(p.Character) end
    end
    local npcwr = WS:FindFirstChild("npcwr")
    if npcwr then
        for _, d in pairs(npcwr:GetDescendants()) do
            if d:IsA("Model") and (d.Name == "bot 1" or d.Name == "bot 3") then tryAdd(d) end
        end
    end
    table.sort(list, function(a,b) return a.score < b.score end)
    return list
end

local function qb_cycleReceiver(rev)
    qb_receiverList = qb_buildReceiverList()
    if #qb_receiverList == 0 then return end
        if qb_data.target then
        for i, r in ipairs(qb_receiverList) do
            if r.char == qb_data.target then qb_receiverIdx = i; break end
        end
    end
    if rev then
        qb_receiverIdx = qb_receiverIdx - 1
        if qb_receiverIdx < 1 then qb_receiverIdx = #qb_receiverList end
    else
        qb_receiverIdx = qb_receiverIdx + 1
        if qb_receiverIdx > #qb_receiverList then qb_receiverIdx = 1 end
    end
    local r = qb_receiverList[qb_receiverIdx]
    if not r then return end
    qb_lockedTarget   = r.char
    qb_data.target    = r.char
    qb_data.smoothVel = Vector3.new()
    qb_HL.Adornee     = r.char
    qb_HL.Enabled     = qbEnabled
