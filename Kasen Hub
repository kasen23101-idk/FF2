local function qb_doThrow(dirUnit, power)
    if not qbEnabled or qb_throwCooldown then return end
    local tool = Char and Char:FindFirstChildOfClass("Tool"); if not tool then return end
    local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("BasePart")
    if not handle then return end
    local Remote = handle:FindFirstChildOfClass("RemoteEvent")
        or tool:FindFirstChildOfClass("RemoteEvent")
        or tool:FindFirstChild("RemoteEvent", true)
    if not Remote then return end
    pcall(function() handle.CanCollide = false end)
    qb_throwCooldown = true
    task.delay(0.13, function()
        if not handle or not handle.Parent then qb_throwCooldown = false; return end
        local origin = handle.Position
        local tgt    = origin + dirUnit * 10000
        if game.PlaceId == 8206123457 then
            pcall(function() Remote:FireServer("Clicked", origin, tgt, power) end)
        else
            local ok = pcall(function() Remote:FireServer("Clicked", origin, tgt, 1, power) end)
            if not ok then pcall(function() Remote:FireServer("Clicked", origin, tgt, power) end) end
        end
        task.delay(0.25, function()
            if handle and handle.Parent then handle.CanCollide = true end
        end)
        task.delay(0.4, function() qb_throwCooldown = false end)
    end)
end

local function qb_executeThrow()
    if not qbEnabled or qb_throwCooldown then return end
    if not qb_data.target or not qb_data.target.Parent then return end
    local head = Char and Char:FindFirstChild("Head")
    if not head or not Char:FindFirstChildOfClass("Tool") then return end

    local hrp     = qb_data.target:FindFirstChild("HumanoidRootPart")
    local tPos    = hrp and hrp.Position or qb_data.target:GetPivot().Position
    local calcV, solvedAngle, airtime, predicted =
        qb_calcThrow(head.Position, tPos, qb_data.smoothVel, qb_autoAngle, qb_Throwtypemode)

        local power = (not qb_autoPower and qb_getGuiPower()) or calcV
    if not power or power <= 0 then return end
    if airtime <= 0 then return end

            local fromPos  = head.Position
    local toFlat   = Vector3.new(predicted.X - fromPos.X, 0, predicted.Z - fromPos.Z)
    local flatDist = toFlat.Magnitude

    local dirUnit
    if flatDist > 0.1 then
        local horizontal = toFlat.Unit
        local ar         = math.rad(solvedAngle)
        local vH         = math.cos(ar)   -- horizontal component (normalised)
        local vV         = math.sin(ar)   -- vertical component (normalised)
        dirUnit = Vector3.new(horizontal.X * vH, vV, horizontal.Z * vH)
        if dirUnit.Magnitude > 0 then
            dirUnit = dirUnit.Unit
        else
                        local fb = predicted - fromPos
            if fb.Magnitude < 0.1 then return end
            dirUnit = fb.Unit
        end
    else
                dirUnit = Vector3.new(0, 1, 0)
    end

    qb_doThrow(dirUnit, power)
end

