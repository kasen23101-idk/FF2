            l.Text=txt; l.TextColor3=col or Color3.fromRGB(210,225,255)
            l.TextSize=sz or 14; l.TextXAlignment=Enum.TextXAlignment.Center; return l
        end

        lbl("Kasen Hub",18,26,true,Color3.fromRGB(210,225,255))
        lbl("Football Fusion 2",48,13,false,Color3.fromRGB(40,110,255))
        lbl("Enter your key below",68,13,false,Color3.fromRGB(120,145,185))

        local box=Instance.new("TextBox",kf)
        box.BackgroundColor3=Color3.fromRGB(14,20,32); box.BorderSizePixel=0
        box.Position=UDim2.new(0,18,0,96); box.Size=UDim2.new(1,-36,0,isMob and 52 or 44)
        box.Font=Enum.Font.GothamBold; box.PlaceholderText="KSN-X-XXXXXX-XXXXXX-XXXXXX"
        box.PlaceholderColor3=Color3.fromRGB(70,95,140); box.Text=""
        box.TextColor3=Color3.fromRGB(210,225,255); box.TextSize=isMob and 15 or 13
        box.ClearTextOnFocus=false; box.TextXAlignment=Enum.TextXAlignment.Center
        Instance.new("UICorner",box).CornerRadius=UDim.new(0,8)
        local bStroke=Instance.new("UIStroke",box)
        bStroke.Color=Color3.fromRGB(25,55,120); bStroke.Thickness=1.5

        local status   = lbl("", isMob and 160 or 152, 13, false, Color3.fromRGB(185,50,50))
        local timeLbl  = lbl("", isMob and 176 or 168, 12, false, Color3.fromRGB(70,95,140))
        local btnY     = isMob and 196 or 186

        local btn=Instance.new("TextButton",kf)
        btn.BackgroundColor3=Color3.fromRGB(40,110,255); btn.BorderSizePixel=0
        btn.Position=UDim2.new(0,18,0,btnY); btn.Size=UDim2.new(1,-36,0,isMob and 56 or 50)
        btn.Font=Enum.Font.GothamBold; btn.Text="Confirm Key"
        btn.TextColor3=Color3.fromRGB(255,255,255); btn.TextSize=isMob and 17 or 15
        Instance.new("UICorner",btn).CornerRadius=UDim.new(0,9)
        Instance.new("UIStroke",btn).Color=Color3.fromRGB(70,140,255)

        lbl("Keys start counting on first use", btnY+60, 11, false, Color3.fromRGB(70,95,140))

        local function shake()
            local orig=kf.Position
            for i=1,8 do
                kf.Position=UDim2.new(0.5,(i%2==0 and 8 or -8),0.5,0)
                task.wait(0.032)
            end
            kf.Position=orig
        end

        local function acceptKey(key, keyDef, secondsLeft)
            validated = true
            status.TextColor3 = Color3.fromRGB(35,160,90)
            status.Text = "✓ Key accepted! ("..keyDef.label..")"
            timeLbl.TextColor3 = Color3.fromRGB(35,160,90)
            timeLbl.Text = fmtTime(secondsLeft)
            btn.BackgroundColor3 = Color3.fromRGB(35,160,90)
            btn.Text = "Loading..."
            -- save key + active pointer
            acts[key]       = now() + secondsLeft
            acts["_active"] = key
            saveActivations(acts)
            task.wait(0.7)
            sg:Destroy()
        end

        local function tryKey()
            local key = box.Text:match("^%s*(.-)%s*$"):upper()
            if key == "" then
                status.TextColor3 = Color3.fromRGB(185,50,50)
                status.Text = "Enter a key first."
                return
            end

            local keyDef = KEYS[key]
            if not keyDef then
                status.TextColor3 = Color3.fromRGB(185,50,50)
                status.Text = "✗  Invalid key."
                timeLbl.Text = ""
                shake(); return
            end

            local reloaded_acts = loadActivations()
            local n = now()

            if reloaded_acts[key] then
                local secondsLeft = reloaded_acts[key] - n
                if secondsLeft > 0 then
                    acts = reloaded_acts
                    acceptKey(key, keyDef, secondsLeft)
                else
                    -- expired on this machine
                    reloaded_acts[key]       = nil
                    reloaded_acts["_active"] = nil
                    saveActivations(reloaded_acts)
                    status.TextColor3 = Color3.fromRGB(185,130,40)
                    status.Text = "✗  Key expired. Get a new one."
                    timeLbl.TextColor3 = Color3.fromRGB(150,100,30)
                    timeLbl.Text = keyDef.label.." — expired"
                    shake()
                end
            else
                -- first use — stamp expiry now
                local expiresAt = n + daysToSec(keyDef.days)
                reloaded_acts[key]       = expiresAt
                reloaded_acts["_active"] = key
                saveActivations(reloaded_acts)
                acceptKey(key, keyDef, daysToSec(keyDef.days))
            end
        end

        btn.MouseButton1Click:Connect(tryKey)
        box.FocusLost:Connect(function(enter) if enter then tryKey() end end)
        repeat task.wait(0.05) until validated
