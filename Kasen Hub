local function qb_clampOOB(targetPos)
    if not qb_antiOOB then return targetPos end
    local bbounds = Workspace:FindFirstChild("bbounds")
    if not bbounds then return targetPos end
    local p, s = bbounds.Position, bbounds.Size
    return Vector3.new(
        math.clamp(targetPos.X, p.X - s.X/2 + 1, p.X + s.X/2 - 1),
        targetPos.Y,
        math.clamp(targetPos.Z, p.Z - s.Z/2 + 1, p.Z + s.Z/2 - 1)
    )
end

local function qb_solveAngle(fromPos, toPos, g)
    local disp = toPos - fromPos
    local xz   = Vector3.new(disp.X, 0, disp.Z).Magnitude
    local dy   = disp.Y
    local pm   = qb_PassMode[qb_Throwtypemode] or qb_PassMode["Dime"]
    local step = pm.step or 0.25

        local function tryAngle(ad)
        local ar   = math.rad(ad)
        local cosA = math.cos(ar)
        if math.abs(cosA) < 0.001 then return nil end
        local num = g * xz * xz
        local den = 2 * cosA * cosA * (xz * math.tan(ar) - dy)
        if den <= 0 then return nil end
        local v2 = num / den
        if v2 <= 0 or v2 ~= v2 or v2 == math.huge then return nil end
        local v = math.sqrt(v2)
        if v > 95 then return nil end
        local t = xz / (v * cosA)
        return v, t
    end

    local bestV, bestA, bestT = 0, qb_manualAngle, 0

    if qb_autoAngle then
                local aMin = pm.angleMin
        local aMax = pm.angleMax
        local mid  = (aMin + aMax) / 2
        for ad = aMin, aMax, step do
            local v, t = tryAngle(ad)
            if v then
                local score = v * 0.2 + math.abs(ad - mid) * 0.5
                local bestScore = bestV * 0.2 + math.abs(bestA - mid) * 0.5
                if bestV == 0 or score < bestScore then
                    bestV = v; bestA = ad; bestT = t
                end
            end
        end
    else
                local v, t = tryAngle(qb_manualAngle)
        if v then
            bestV = v; bestA = qb_manualAngle; bestT = t
        else
                                    local found = false
            for delta = step, 20, step do
                                for _, ad in ipairs({qb_manualAngle + delta, qb_manualAngle - delta}) do
                    if ad >= 1 and ad <= 80 then
                        local v2, t2 = tryAngle(ad)
                        if v2 then
                            bestV = v2; bestA = ad; bestT = t2
                            found = true; break
                        end
                    end
                end
                if found then break end
            end
        end
    end

    bestV = math.clamp(bestV, 0, 95)
    return bestV, bestA, bestT
end

local function qb_calcThrow(fromPos, toPos, smoothVel, autoAngle, mode)
    local pm   = qb_PassMode[mode] or qb_PassMode["Dime"]
    local lead = pm.leadDistance or 5
    local g    = qb_gMag

    local hvl  = Vector3.new(smoothVel.X, 0, smoothVel.Z)
    local hspd = hvl.Magnitude
    local hdir = hspd > 0.5 and hvl.Unit or Vector3.new()
    local fl   = Vector3.new((toPos-fromPos).X, 0, (toPos-fromPos).Z).Magnitude

    local function buildPred(t)
        local velLead    = hvl * t
        local sliderLead = hdir * lead * math.clamp(hspd / 4, 0, 1)
        local heightComp = Vector3.new(0, math.clamp(fl * 0.025, 0.3, 3.0), 0)
        return qb_clampOOB(toPos + velLead + sliderLead + heightComp)
    end

        local initT = math.max(fl / 40, 0.15)
    local pred  = buildPred(initT)
    local bV, bA, bT = qb_solveAngle(fromPos, pred, g)

            if qb_autoAngle then
        for _ = 1, 5 do
            if bT > 0.05 and bV > 0 then
                local newPred = buildPred(bT)
                local nV, nA, nT = qb_solveAngle(fromPos, newPred, g)
                if nV > 0 and math.abs(nT - bT) < 0.4 then
                    pred = newPred; bV = nV; bA = nA; bT = nT
                else break end
            else break end
        end
    end

    bV = math.clamp(bV, 0, 95)
    qb_data.power     = bV
    qb_data.angle     = bA
    qb_data.airtime   = bT
    qb_data.targetPos = pred
    return bV, bA, bT, pred
end

